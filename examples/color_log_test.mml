// Color Log Test
fn void main() {
    // 设置日志级别为DEBUG
    log.set_level(0);
    
    // 测试不同颜色的日志
    log.debug("青色调试信息");
    log.info("绿色信息日志");
    log.warn("黄色警告信息");
    log.error("红色错误信息");
    
    // 测试服务器日志
    let server_id = network.create_server(8080);
    log.info("服务器创建完成");
    
    return 0;
}
