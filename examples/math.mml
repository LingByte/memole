package math;

fn int add(int x, int y) {
    return x + y;
}

fn int subtract(int x, int y) {
    return x - y;
}

fn int multiply(int x, int y) {
    return x * y;
}

fn int divide(int x, int y) {
    return x / y;
}

fn int power(int base, int exp) {
    let result = 1;
    let i = 0;
    while (i < exp) {
        result = result * base;
        i = i + 1;
    }
    return result;
}
