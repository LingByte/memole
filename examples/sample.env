# 应用程序配置
APP_NAME=MML Language
VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mml_db
DB_USER=root
DB_PASSWORD=password

# 网络配置
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
TIMEOUT=30.5

# 日志配置
LOG_LEVEL=info
LOG_FILE=app.log
ENABLE_LOGGING=true

# 其他配置
MAX_CONNECTIONS=100
CACHE_SIZE=1024
